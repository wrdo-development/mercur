{
  "name": "mercur",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "oxlint --quiet",
    "test:integration:http": "cd integration-tests && bun run test:integration:http",
    "test:e2e": "cd e2e-tests && bun run test",
    "test:e2e:ui": "cd e2e-tests && bun run test:ui"
  },
  "dependencies": {
    "@mercurjs/core": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "oxlint": "^1.64.0",
    "prettier": "^3.7.4",
    "turbo": "^2.7.4",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.53.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/providers/*",
    "integration-tests",
    "e2e-tests"
  ],
  "overrides": {
    "@medusajs/admin-bundler": "2.13.4",
    "@medusajs/admin-sdk": "2.13.4",
    "@medusajs/admin-shared": "2.13.4",
    "@medusajs/admin-vite-plugin": "2.13.4",
    "@medusajs/cli": "2.13.4",
    "@medusajs/core-flows": "2.13.4",
    "@medusajs/dashboard": "2.13.4",
    "@medusajs/draft-order": "2.13.4",
    "@medusajs/framework": "2.13.4",
    "@medusajs/icons": "2.13.4",
    "@medusajs/medusa": "2.13.4",
    "@medusajs/test-utils": "2.13.4",
    "@medusajs/types": "2.13.4",
    "@medusajs/ui": "4.1.1",
    "@medusajs/ui-preset": "2.13.4",
    "zod": "3.25.76"
  }
}